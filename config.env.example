# Telegram Bot Configuration
# Copy this file to config.env and fill in your values

# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789

# Search keywords (comma-separated for multiple areas)
# Multi-word areas with spaces MUST be quoted (e.g., "Bel-air,Pasong Camachile 1")
SEARCH_AREAS="Bel-air,Pasong Camachile 1"
